# Wurzel API — local development environment
# Copy this file to .env and fill in the values from `supabase start` output.
#
# NEVER commit a populated .env file.

# ── API ───────────────────────────────────────────────────────────────────────
API__API_KEY=change-me-before-use
API__DEBUG=true
API__CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ── Supabase (from `supabase start` output) ───────────────────────────────────
SUPABASE__URL=http://127.0.0.1:54321
SUPABASE__SERVICE_KEY=<service_role_key_from_supabase_start>

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# JWKS URL for local Supabase — token secret is in the supabase start output.
AUTH__JWKS_URL=http://127.0.0.1:54321/auth/v1/.well-known/jwks.json
AUTH__JWT_AUDIENCE=authenticated
AUTH__ALGORITHM=HS256
# Set to false to bypass JWT validation in local dev (never in production!)
AUTH__ENABLED=true

# ── OTEL (optional) ───────────────────────────────────────────────────────────
OTEL__ENABLED=false
OTEL__SERVICE_NAME=wurzel-api-local
